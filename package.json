{
  "name": "@craf-te/canvas-buffer-viewer",
  "author": "CRAF'TE",
  "version": "1.1.0",
  "description": "WebGL framebuffer/depth buffer visualization debug tool",
  "type": "module",
  "main": "./dist/index.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/craf-te/canvas-buffer-viewer.git"
  },
  "homepage": "https://github.com/craf-te/canvas-buffer-viewer",
  "bugs": {
    "url": "https://github.com/craf-te/canvas-buffer-viewer/issues"
  },
  "keywords": [
    "webgl",
    "three.js",
    "debug",
    "framebuffer",
    "depth-buffer",
    "canvas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite demo",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "three": "^0.170.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "license": "MIT"
}
